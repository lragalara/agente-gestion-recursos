# -- Modo BC ---------------------------------------------------------------
# mock = usa mock_bc server local
# live = usa BC On-Premise real via gateway
BC_MODE=mock

# -- Resolucion de empresa BC (tenant) ------------------------------------
# fixed  = usa siempre BC_COMPANY_ID
# select = el bot pregunta al usuario que empresa quiere usar al inicio
# auto   = autodetecta via grupos de Entra ID (requiere BOT_APP_ID)
BC_TENANT_MODE=fixed
BC_COMPANY_ID=CRONUS

# -- Azure OpenAI ----------------------------------------------------------
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-02-01

# -- Azure Bot Service -----------------------------------------------------
BOT_APP_ID=
BOT_APP_PASSWORD=

# -- BC OData: solo cuando BC_MODE=live -----------------------------------
BC_GATEWAY_URL=
BC_ODATA_USER=
BC_ODATA_PASSWORD=

# -- Alertas proactivas: routing por rol ----------------------------------
# El mapeo principal rol -> Teams user_id vive en:
#   orchestrator/config/alert_roles.json
# Estas variables permiten override o fallback por entorno.
# Puedes poner uno o varios Object IDs separados por coma.
ALERT_ROLE_COMPRAS=
ALERT_ROLE_RRHH=
ALERT_ROLE_FLOTA=
ALERT_ROLE_TECNICO=
ALERT_ROLE_RESPONSABLE=
ALERT_ROLE_COMPRAS_EMAILS=
ALERT_ROLE_RRHH_EMAILS=
ALERT_ROLE_FLOTA_EMAILS=
ALERT_ROLE_TECNICO_EMAILS=
ALERT_ROLE_RESPONSABLE_EMAILS=

# -- Power Automate: notificaciones ---------------------------------------
# Usa 2 flows distintos:
#   PA_NOTIFY_FLOW_URL_OPERATIONS -> Delivery / Return / Transfer
#   PA_NOTIFY_FLOW_URL_ALERTS     -> alertas proactivas
# PA_NOTIFY_FLOW_URL queda como fallback legado opcional.
PA_NOTIFY_FLOW_URL_OPERATIONS=
PA_NOTIFY_FLOW_URL_ALERTS=
PA_NOTIFY_FLOW_URL=

# -- Mock BC: solo cuando BC_MODE=mock ------------------------------------
MOCK_BC_URL=http://mock_bc:8001
