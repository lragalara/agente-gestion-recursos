# ── Modo BC ──────────────────────────────────────────────────────────
# mock = usa mock_bc server local
# live = usa BC On-Premise real vía gateway
BC_MODE=mock

# ── Resolución de empresa BC (tenant) ────────────────────────────────
# fixed  = usa siempre BC_COMPANY_ID (desarrollo y empresas con un solo tenant)
# select = el bot pregunta al usuario qué empresa quiere usar al inicio
# auto   = autodetecta via grupos de Entra ID (requiere BOT_APP_ID configurado)
BC_TENANT_MODE=fixed
BC_COMPANY_ID=CRONUS

# ── Azure OpenAI ─────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-02-01

# ── Azure Bot Service ────────────────────────────────────────────────
BOT_APP_ID=
BOT_APP_PASSWORD=

# ── BC OData — solo cuando BC_MODE=live ──────────────────────────────
BC_GATEWAY_URL=
BC_ODATA_USER=
BC_ODATA_PASSWORD=

# ── Power Automate flows — solo cuando BC_MODE=live ──────────────────
PA_RELEASE_FLOW_URL=
PA_POST_FLOW_URL=

# ── Mock BC — solo cuando BC_MODE=mock ───────────────────────────────
MOCK_BC_URL=http://mock_bc:8001
